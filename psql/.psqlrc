\set QUIET 1
\set comp_keyword_case lower
\set show_slow_queries
\pset null '(null)'
\pset linestyle unicode
\pset pager on
\pset format aligned
\pset border 2
\pset tuples_only off
\pset footer
\set QUIET 0
--\setenv PAGER 'ov --view-mode psql --config ~/.config/ov/ov.yaml'
\setenv PAGER 'less -F'
\x auto
